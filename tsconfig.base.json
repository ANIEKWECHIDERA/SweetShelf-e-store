{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@sweetshelf/shared-types": ["packages/shared-types/src/index.ts"],
      "@sweetshelf/shared-ui": ["packages/shared-ui/src/index.ts"],
      "@sweetshelf/shared-config/*": ["packages/shared-config/*"]
    }
  }
}

{
  "extends": "../../packages/shared-config/tsconfig/nextjs.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
